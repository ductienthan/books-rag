# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+psycopg://bookrag:bookrag@localhost:5432/bookrag
ASYNC_POSTGRES_URL=postgresql+asyncpg://bookrag:bookrag@localhost:5432/bookrag

# ── Ollama (LLM only — embeddings use sentence-transformers directly) ─────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_LLM_MODEL=gemma4:e4b

# ── Embedding model (HuggingFace / sentence-transformers) ─────────────────────
EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBED_BATCH_SIZE=32
EMBED_DIM=768

# ── pgvector HNSW ─────────────────────────────────────────────────────────────
HNSW_EF_SEARCH=40

# ── Ingestion ─────────────────────────────────────────────────────────────────
# Pages with fewer than this many characters trigger EasyOCR fallback
OCR_CHAR_THRESHOLD=100
# Max books allowed in the system
MAX_BOOKS=50

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
# Cosine similarity threshold below which results are considered out-of-scope
COSINE_THRESHOLD=0.35

# ── Phase 2: Context Expansion ────────────────────────────────────────────────
# Maximum tokens to include in LLM context (Phase 1: ~1,750 → Phase 2: 4,000)
MAX_CONTEXT_TOKENS=4000
# Maximum chunks to retrieve for detailed/analytical questions
MAX_RETRIEVAL_CHUNKS=12
# Minimum chunks for simple queries
MIN_RETRIEVAL_CHUNKS=5
# Enable adaptive context sizing (adjusts based on question complexity)
ADAPTIVE_CONTEXT=true

# ── Phase 3: Caching ──────────────────────────────────────────────────────────
# Enable answer caching (reduces repeated query time from 90-150s to <5s)
ENABLE_ANSWER_CACHE=true
# Enable embedding caching (saves 2-5s per query by avoiding model calls)
ENABLE_EMBEDDING_CACHE=true
# Cache directory location (relative to project root)
CACHE_DIR=.cache
# Answer cache time-to-live in seconds (3600 = 1 hour)
ANSWER_CACHE_TTL=3600
# Maximum total cache size in MB (500 = limit to 500MB, 0 = unlimited)
MAX_CACHE_SIZE_MB=500

# ── Phase 3: BM25 Hybrid Search ───────────────────────────────────────────────
# Enable BM25 keyword search (improves recall for technical terms, acronyms)
ENABLE_BM25=true
# BM25 index storage directory
BM25_INDEX_DIR=.indexes/bm25
# BM25 weight in hybrid search (0.3 = 30% keyword, 70% semantic)
BM25_WEIGHT=0.3
# Vector search weight in hybrid search (0.7 = 70% semantic, 30% keyword)
VECTOR_WEIGHT=0.7
# Number of BM25 candidates to retrieve before fusion
BM25_TOP_K=40

# ── Agent / LLM ───────────────────────────────────────────────────────────────
LLM_MAX_TOKENS=512
SESSION_MEMORY_WINDOW=6

# ── Phase 3.3: Streaming ──────────────────────────────────────────────────────
# Enable streaming LLM output (shows answer as it's generated in real-time)
ENABLE_STREAMING=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
